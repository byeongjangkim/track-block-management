# ─────────────────────────────────────────────────────────────────
# 선로차단작업 관리 - 프로덕션 환경 설정
# 이 파일을 .env 로 복사한 뒤 값을 채워넣으세요:
#   cp .env.template .env
# ─────────────────────────────────────────────────────────────────

# ── DB ────────────────────────────────────────────────────────────
DB_USER=tbm
DB_PASSWORD=CHANGE_THIS_DB_PASSWORD

# ── 보안 ──────────────────────────────────────────────────────────
# openssl rand -hex 32  로 생성
SECRET_KEY=CHANGE_THIS_SECRET_KEY_32CHARS_MIN
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── 배포 모드 선택 ────────────────────────────────────────────────
#
# [모드 A] 독립 포트 (기본 권장)  — team-work-manager 무수정
#   - 접속 주소: http://10.10.10.10:8080
#   - EXPOSE_PORT=8080
#   - VITE_BASE_PATH=  (빈값)
#   - VITE_API_URL=http://10.10.10.10:8080
#
# [모드 B] nginx 경로 통합  — 기존 nginx에 location 블록 추가 필요
#   - 접속 주소: http://10.10.10.10/track
#   - EXPOSE_PORT=  (빈값 — nginx 내부에서만 통신)
#   - VITE_BASE_PATH=/track/
#   - VITE_API_URL=  (빈값 — 상대 경로 사용)
#
# ─────────────────────────────────────────────────────────────────

# 모드 A 기본값 (모드 B는 아래 주석 참고)
EXPOSE_PORT=8080
VITE_BASE_PATH=
VITE_API_URL=http://10.10.10.10:8080

# 모드 B 사용 시 위 3줄을 아래로 교체:
# EXPOSE_PORT=
# VITE_BASE_PATH=/track/
# VITE_API_URL=
